{
  "name": "scramjet-browser",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A minimal, modern dark-theme browser homepage powered by the Scramjet proxy engine.",
  "scripts": {
    "copy-assets": "node scripts/copy-scramjet-assets.mjs",
